{
	"name": "crckc-bible-together",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --port=4000",
		"build": "bun run getFirestoreHelpers && vite build",
		"vbuild": "vite build",
		"preview": "vite preview",
		"test": "bun run test:integration && bun run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"getFirestoreHelpers": "mkdir -p static/__/auth && mkdir -p static/__/firebase && curl -o 'static/__/auth/#1' 'https://bibletogether.firebaseapp.com/__/auth/{handler.js,iframe.js,experiments.js}' && curl -o 'static/__/auth/#1.html' 'https://bibletogether.firebaseapp.com/__/auth/{handler,iframe}' && curl -o 'static/__/firebase/init.json' 'https://bibletogether.firebaseapp.com/__/firebase/init.json'",
		"emulator": "firebase emulators:start",
		"cert": "rm -rf .cert && mkdir -p .cert && mkcert -key-file ./.cert/key.pem -cert-file ./.cert/cert.pem 'localhost'",
		"certDependencies": "sudo apt install libnss3-tools mkcert",
		"setupDev": "bun run certDependencies && bun run cert && bun run getFirestoreHelpers  && cp static/__/auth/handler.html static/__/auth/handler && cp static/__/auth/iframe.html static/__/auth/iframe"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^7.0.1",
		"@iconify-json/material-symbols": "^1.2.14",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.23.0",
		"@playwright/test": "^1.50.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/eslint": "^9.6.1",
		"@vite-pwa/sveltekit": "^1.0.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.20.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^3.0.0",
		"firebase": "^11.3.1",
		"formsnap": "^2.0.1",
		"globals": "^15.15.0",
		"layerchart": "2.0.0-next.48",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.5.1",
		"prettier-plugin-svelte": "^4.0.0",
		"sharp": "^0.33.5",
		"svelte": "^5.33.0",
		"svelte-check": "^4.1.4",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "2.23.1",
		"tailwind-merge": "^2.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.24.1",
		"unplugin-icons": "^0.19.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^6.0.0",
		"vite-plugin-pwa": "^0.21.1",
		"vitest": "3",
		"workbox-build": "^7.3.0",
		"workbox-core": "^7.3.0",
		"workbox-precaching": "^7.3.0",
		"workbox-routing": "^7.3.0",
		"workbox-strategies": "^7.3.0",
		"workbox-window": "^7.3.0",
		"zod": "^3.24.2",
		"zod-v3-to-json-schema": "^4.0.0"
	},
	"type": "module",
	"dependencies": {
		"@capacitor-firebase/authentication": "^7.0.0",
		"@capacitor/android": "^7.0.1",
		"@capacitor/core": "^7.0.1",
		"jszip": "^3.10.1",
		"svelte-i18n": "^4.0.1",
		"svelte-persisted-store": "^0.12.0"
	},
	"trustedDependencies": [
		"@firebase/util",
		"es5-ext",
		"esbuild",
		"protobufjs",
		"sharp"
	]
}
